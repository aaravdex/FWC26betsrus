# --- Database (PostgreSQL) ---
# Point this at your Postgres instance. The app and Prisma both read DATABASE_URL.
# On Railway, set this to a reference to the Postgres service: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worldcup?schema=public"

# --- App ---
# Public base URL of the deployment (used for absolute links).
APP_URL="http://localhost:3000"

# Fixed starting play-money balance granted to every new account (points).
STARTING_BALANCE="1000"

# --- Seeding (used only by `npm run db:seed`) ---
# Initial admin password. Set this for any real deployment so the admin account
# is NOT seeded with the default "admin12345".
ADMIN_PASSWORD="admin12345"

# When "true", the seed also creates demo players (alice/bob/...) + sample bets
# + one settled fixture. Leave unset/false in production for a clean leaderboard.
SEED_DEMO="false"

# Note: do NOT set NODE_ENV on Railway/Nixpacks — the build needs devDependencies,
# and `next start` runs in production mode automatically.
