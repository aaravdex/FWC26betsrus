// World Cup 2026 Predictions — Prisma schema
// PLAY-MONEY ONLY. Every "point" value here is a fictional game token.
// No real currency, no payment rails. Balances are reconstructable from the
// immutable LedgerEntry table.
//
// Points are BigInt: the supplied odds reach 50000.00, so a single winning bet
// can return billions of points — beyond a 32-bit int. BigInt (int8) gives huge
// head-room while staying exact (no floating point on money).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  PLAYER
}

enum MatchStatus {
  SCHEDULED // betting open until kickoff
  LOCKED    // kickoff passed / manually locked — no new bets
  SETTLED   // result entered, bets paid
  CANCELLED // match cancelled — open bets voided & refunded
  POSTPONED // match postponed — betting closed until rescheduled
}

enum MarketKind {
  MATCH_WINNER      // Team A win / Draw / Team B win for a match
  TOURNAMENT_WINNER // which team wins the World Cup
  TOP_SCORER        // which player scores the most goals
  ROUND_OF_16       // will a team qualify from the group stage (one outcome per team, each settles yes/no)
}

enum MarketStatus {
  OPEN
  SUSPENDED // admin paused betting (reversible) — shows a "betting paused" overlay
  LOCKED
  SETTLED
}

// Live play state for the Match Center scoreboard (separate from betting status).
enum MatchLiveStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FULLTIME
}

// Admin-appended match timeline events. No external feed — admin enters these.
enum MatchEventType {
  KICKOFF
  GOAL
  OWN_GOAL
  PENALTY_SCORED
  PENALTY_MISSED
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  INJURY
  VAR
  HALFTIME
  FULLTIME
  NOTE
}

// Result of a single selection once its market is settled.
enum OutcomeResult {
  PENDING
  WON
  LOST
  VOID
}

enum BetStatus {
  OPEN
  WON
  LOST
  VOID
}

// Every balance movement is one of these. The ledger is append-only.
enum LedgerType {
  INITIAL_GRANT // points granted when a user joins
  STAKE         // points removed when a bet is placed (negative)
  PAYOUT        // points credited when a bet wins (positive)
  REFUND        // points returned when a bet/market is voided (positive)
  ADJUSTMENT    // manual admin correction (positive or negative)
}

// ---------------------------------------------------------------------------
// Auth / users / sessions
// ---------------------------------------------------------------------------

model User {
  id String @id @default(cuid())
  // Public display name AND login handle. No email is stored anywhere.
  username     String @unique
  // argon2id/bcrypt hash — never plaintext. (We use bcrypt via bcryptjs.)
  passwordHash String
  role         Role   @default(PLAYER)
  // Cached balance in points. Source of truth is the ledger; this column is
  // always written inside the same transaction as the ledger entry that
  // changes it, so it stays exactly equal to SUM(ledger.amount).
  balance   BigInt   @default(0)
  // Set when an admin bans/disables the account — blocks login, data is kept.
  bannedAt  DateTime?
  createdAt DateTime @default(now())

  sessions      Session[]
  bets          Bet[]
  ledgerEntries LedgerEntry[]
  chatMessages  ChatMessage[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique // random opaque token stored in an httpOnly cookie
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Tournament structure
// ---------------------------------------------------------------------------

// Singleton row (id = 1) holding tournament-wide settings.
model TournamentSettings {
  id   Int    @id @default(1)
  name String @default("World Cup 2026")
  // Lock time for tournament-level markets (winner, top scorer).
  startsAt        DateTime
  startingBalance BigInt   @default(1000)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Team {
  id         String   @id @default(cuid())
  name       String   @unique
  code       String   @unique // e.g. FRA, BRA
  group      String? // e.g. "A"
  eliminated Boolean  @default(false)
  createdAt  DateTime @default(now())

  homeMatches Match[]      @relation("HomeTeam")
  awayMatches Match[]      @relation("AwayTeam")
  players     Player[]
  outcomes    Outcome[] // tournament-winner selections pointing at this team
  matchEvents MatchEvent[]
}

model Player {
  id        String   @id @default(cuid())
  name      String
  position  String?
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())

  outcomes Outcome[] // top-scorer selections pointing at this player
}

model Match {
  id         String      @id @default(cuid())
  homeTeamId String // "Team A" in the supplied odds table
  homeTeam   Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId String // "Team B"
  awayTeam   Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoff    DateTime // seeded as an editable placeholder; admin sets real time
  status     MatchStatus @default(SCHEDULED)
  venue      String? // optional stadium/city; shown only if present
  // Live Match Center (admin-driven; no external feed).
  liveStatus MatchLiveStatus @default(SCHEDULED)
  minute     Int? // admin-set match minute while live
  // Current score. Admin updates these live; settlement reads the final values.
  homeScore Int?
  awayScore Int?
  settledAt DateTime?
  createdAt DateTime    @default(now())

  markets Market[]
  events  MatchEvent[]

  @@index([kickoff])
}

// One admin-entered timeline event for a match (newest-first feed).
model MatchEvent {
  id          String         @id @default(cuid())
  matchId     String
  match       Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type        MatchEventType
  minute      Int?
  teamId      String? // which team the event relates to (optional)
  team        Team?          @relation(fields: [teamId], references: [id])
  description String? // optional admin note, e.g. scorer name
  createdAt   DateTime       @default(now())

  @@index([matchId])
}

// ---------------------------------------------------------------------------
// Markets, outcomes (selections) and bets
// ---------------------------------------------------------------------------

model Market {
  id     String       @id @default(cuid())
  kind   MarketKind
  title  String
  status MarketStatus @default(OPEN)

  // For MATCH_WINNER this is the match the market belongs to. Null for the
  // tournament-level markets (winner, top scorer).
  matchId String?
  match   Match?  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Betting closes at this instant (kickoff for match markets, tournament
  // start for tournament-level markets). Enforced at placement time.
  locksAt   DateTime
  settledAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  outcomes Outcome[]
  bets     Bet[]

  @@index([matchId])
  @@index([kind])
}

model Outcome {
  id       String @id @default(cuid())
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId String

  // Stable key within a market: HOME/DRAW/AWAY for match winner; for the
  // tournament-level markets a team code or player slug / ANY_OTHER.
  selectionKey String
  label        String // display name shown to users
  // Decimal payout multiplier locked onto a bet at placement time. A winning
  // stake returns stake * odds in total. Supplied values reach 50000.00.
  odds Decimal @db.Decimal(12, 2)
  // Previous odds value + when it changed — used purely to render a green-up /
  // red-down arrow when an admin edits the odds. No simulated movement.
  previousOdds  Decimal?  @db.Decimal(12, 2)
  oddsUpdatedAt DateTime?

  // Optional links for tournament-level selections.
  teamId   String?
  team     Team?   @relation(fields: [teamId], references: [id])
  playerId String?
  player   Player? @relation(fields: [playerId], references: [id])

  result    OutcomeResult @default(PENDING)
  createdAt DateTime      @default(now())

  bets Bet[]

  @@unique([marketId, selectionKey])
  @@index([marketId])
}

model Bet {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcomeId String
  outcome   Outcome @relation(fields: [outcomeId], references: [id])

  stake           BigInt // points staked (positive)
  oddsAtPlacement Decimal   @db.Decimal(12, 2) // odds snapshot — independent of later edits
  potentialReturn BigInt // round(stake * oddsAtPlacement) — credited if it wins
  status          BetStatus @default(OPEN)
  placedAt        DateTime  @default(now())
  settledAt       DateTime?

  ledgerEntries LedgerEntry[]

  @@index([userId])
  @@index([marketId])
  @@index([outcomeId])
}

// Append-only ledger. Never updated or deleted. balanceAfter is a snapshot of
// the user's running balance immediately after this entry was applied.
model LedgerEntry {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       BigInt // signed: negative removes points, positive adds points
  type         LedgerType
  description  String
  balanceAfter BigInt
  betId        String?
  bet          Bet?       @relation(fields: [betId], references: [id])
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([betId])
}

// ---------------------------------------------------------------------------
// Leaderboard chat (real-time via client polling)
// ---------------------------------------------------------------------------

model ChatMessage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Raw text only. Rendered as plain text (React escapes it) — never as HTML.
  body String
  // Admin soft-delete: row is kept for audit; body is hidden in the UI.
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// In-app notifications (no email/push). Generated from real app events.
// ---------------------------------------------------------------------------

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SETTLEMENT | RANK | KICKOFF_SOON | ANNOUNCEMENT (free string, no enum churn)
  type  String
  title String
  body  String
  href  String? // optional deep link, e.g. /matches/<id>
  // For idempotent generation (e.g. "settled:<marketId>", "kickoff:<matchId>").
  dedupeKey String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
}
